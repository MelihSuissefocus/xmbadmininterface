# Environment Configuration for XMB Admin Portal
# Copy this file to .env.local and fill in the values with your REAL credentials
# NEVER commit .env.local to version control

# Database (Neon PostgreSQL - Production Database)
# Get your DATABASE_URL from Neon Console → Project → Connection Details
# Format: postgresql://user:password@host/database?sslmode=require
# 
# IMPORTANT: This should be your REAL Neon production database URL
# The CI script (npm run ci:local) will apply migrations to this database
DATABASE_URL="postgresql://user:password@ep-xxx-xxx.region.neon.tech/dbname?sslmode=require"

# Auth.js Secret (required for JWT signing, min 32 chars)
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-key-min-32-chars-replace-me"

# Mac Mini CV Extraction (optional — falls nicht gesetzt, wird Azure DI verwendet)
# MAC_MINI_API_URL: URL zum Mac Mini FastAPI-Server (z.B. https://dein-tunnel.dev oder http://IP:8000)
# MAC_MINI_API_KEY: API-Key für den Mac Mini (Header: Xmb-pdftojsonapi)
# CV_CALLBACK_SECRET: Shared Secret für Webhook-Auth (Mac Mini → Vercel Callback)
MAC_MINI_API_URL=""
MAC_MINI_API_KEY=""
CV_CALLBACK_SECRET=""

# ============================================================================
# IMPORTANT NOTES:
# ============================================================================
# 1. Get DATABASE_URL from Neon Console:
#    - Navigate to your project
#    - Go to "Connection Details" or "Dashboard"
#    - Copy the "Connection string" (not the pooled connection)
# 2. Use your PRODUCTION Neon database URL here
# 3. The CI script (npm run ci:local) applies migrations to this database
# 4. For Vercel deployment, set these as environment variables in Vercel dashboard
# 5. No separate test database needed - migrations run against production DB
# ============================================================================
